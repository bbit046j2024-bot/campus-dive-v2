[mysqld]
datadir=/home/runner/workspace/.mysql/data
socket=/home/runner/workspace/.mysql/run/mysql.sock
pid-file=/home/runner/workspace/.mysql/run/mysql.pid
log-error=/home/runner/workspace/.mysql/logs/error.log
port=3306
bind-address=127.0.0.1
mysqlx=OFF
user=runner
[mysql]
socket=/home/runner/workspace/.mysql/run/mysql.sock
[client]
socket=/home/runner/workspace/.mysql/run/mysql.sock
